# Copy to .env and fill in your Google OAuth credentials.
# Read by both the app (loaded from the working directory) and docker-compose.
# Keys follow the app's convention: __ separates sections, _ is a word break.

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
OAUTH__CLIENT_ID=
OAUTH__CLIENT_SECRET=

# Must match an Authorized redirect URI on the OAuth client.
OAUTH__REDIRECT_URL=http://localhost:5000/api/users/callback

# Secret used to sign JWTs. Change this for anything but a local demo.
JWT__SECRET=dev-secret-change-me
