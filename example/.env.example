# Copy to .env (in the repo root) and fill in your values.
# Read by both the app (loaded from the working directory) and docker-compose.
# Keys follow the app's convention: __ separates sections, _ is a word break.
# Every value below is optional and falls back to the built-in default.

# HTTP server and connection controls.
HTTP__ADDR=localhost
HTTP__PORT=5000
HTTP__READ_TIMEOUT=15s
HTTP__READ_HEADER_TIMEOUT=5s
HTTP__WRITE_TIMEOUT=15s
HTTP__IDLE_TIMEOUT=60s
HTTP__SHUTDOWN_TIMEOUT=10s

# PostgreSQL.
DB__HOST=localhost
DB__PORT=5432
DB__USER=mayigoo
DB__PASSWORD=mayigoo
DB__NAME=mayigoo
DB__SSL_MODE=disable
DB__MAX_OPEN_CONNS=25
DB__MAX_IDLE_CONNS=25
DB__CONN_MAX_LIFETIME=5m

# Redis.
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__PASSWORD=
REDIS__DB=0

# JWT signing. Change the secret for anything but a local demo.
JWT__SECRET=dev-secret-change-me
JWT__TTL=24h

# Google OAuth 2.0 client (Google Cloud Console → APIs & Services → Credentials).
# REDIRECT_URL must match an Authorized redirect URI on the OAuth client.
OAUTH__CLIENT_ID=
OAUTH__CLIENT_SECRET=
OAUTH__REDIRECT_URL=http://localhost:5000/api/users/callback

# Background daemons.
DAEMONS__USAGE_FLUSH_INTERVAL=10s
DAEMONS__USAGE_BUFFER_SIZE=1024
DAEMONS__HEALTH_PING_INTERVAL=15s

# Logging.
LOG__FORMAT=json   # json or text
LOG__LEVEL=info    # debug, info, warn, error
