# Copy to config.yaml (auto-loaded from the working directory) or point at it
# with MAYIGOO_CONFIG_FILE=/path/to/config.yaml.
#
# Precedence (lowest to highest): defaults < this file < .env < MAYIGOO_* env vars.
# In env vars a double underscore separates sections and a single underscore is a
# word break, e.g. MAYIGOO_DB__SSL_MODE -> db.ssl_mode,
# MAYIGOO_OAUTH__CLIENT_ID -> oauth.client_id.

http:
  addr: "localhost"
  port: 5000
  read_timeout: "15s"
  read_header_timeout: "5s"
  write_timeout: "15s"
  idle_timeout: "60s"
  shutdown_timeout: "10s"

db:
  host: "localhost"
  port: "5432"
  user: "mayigoo"
  password: "mayigoo"
  name: "mayigoo"
  ssl_mode: "disable"
  max_open_conns: 25
  max_idle_conns: 25
  conn_max_lifetime: "5m"

redis:
  host: "localhost"
  port: "6379"
  password: ""
  db: 0

jwt:
  secret: "dev-secret-change-me"
  ttl: "24h"

oauth:
  client_id: ""
  client_secret: ""
  redirect_url: "http://localhost:5000/api/users/callback"

daemons:
  usage_flush_interval: "10s"
  usage_buffer_size: 1024
  health_ping_interval: "15s"
